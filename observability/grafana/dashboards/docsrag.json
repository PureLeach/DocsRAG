{
  "title": "DocsRAG",
  "uid": "docsrag",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(rag_requests_total[1m]) * 60)",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Request Latency p50/p95/p99 (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, handler) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{handler}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{handler}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, handler) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{handler}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Retrieval Duration p50/p95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, endpoint) (rate(rag_retrieval_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(rag_retrieval_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{endpoint}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Generation Duration p50/p95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, endpoint) (rate(rag_generation_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(rag_generation_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{endpoint}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rag_requests_total)",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 6,
      "title": "Avg Answer Length (chars)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(rag_answer_length_chars_sum[5m]) / rate(rag_answer_length_chars_count[5m])",
          "legendFormat": "avg"
        }
      ]
    },
    {
      "id": 7,
      "title": "Avg top_k",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "rate(rag_top_k_sum[5m]) / rate(rag_top_k_count[5m])",
          "legendFormat": "avg"
        }
      ]
    },
    {
      "id": 8,
      "title": "HTTP Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s"
        }
      ]
    }
  ]
}
