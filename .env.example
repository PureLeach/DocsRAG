# Copy to .env and adjust as needed.
# All values shown are defaults from api/config.py.

# QDRANT_URL is intentionally not set here:
# - Docker container gets http://qdrant:6333 from docker-compose.yml
# - Local tools (eval, indexing) use the default http://localhost:6333 from config.py
QDRANT_COLLECTION=docsrag

INFERENCE_BACKEND=ollama

# OLLAMA_BASE_URL is intentionally not set here:
# - Docker container gets http://host.docker.internal:11434 from docker-compose.yml
# - Local tools (eval, indexing) use the default http://localhost:11434 from config.py
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# VLLM_BASE_URL is intentionally not set here:
# - Docker container gets http://host.docker.internal:8001/v1 from docker-compose.yml
# - Local tools (eval) use the default http://localhost:8001/v1 from config.py
# VLLM_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
VLLM_MODEL=mlx-community/Qwen2.5-14B-Instruct-4bit

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

EMBEDDING_DIM=384

CHUNK_SIZE=512
CHUNK_OVERLAP=50

DOCS_SOURCE_PATH=data/raw/fastapi/docs/en/docs

HF_TOKEN=qwerty

# LangFuse tracing (optional — leave empty to disable)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
