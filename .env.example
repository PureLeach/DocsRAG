QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=docsrag

# Inference backend: "ollama" (default) or "vllm"
INFERENCE_BACKEND=ollama

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# vLLM endpoint (vllm-metal locally, vllm+CUDA in production)
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit

# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=384

CHUNK_SIZE=512
CHUNK_OVERLAP=50

DOCS_SOURCE_PATH=data/raw/fastapi/docs/en/docs

HF_TOKEN=qwerty

# LangFuse tracing (optional — leave empty to disable)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL="https://cloud.langfuse.com"
